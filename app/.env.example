# --- Front end (Vite) ---
# Point the app at your Supabase project so it calls the tarot-chat edge function.
# If you leave these blank, the app runs in DEMO mode (offline reading generator).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Or point directly at any tarot-chat-compatible endpoint instead of Supabase:
# VITE_TAROT_CHAT_URL=https://your-host/functions/v1/tarot-chat

# Optional: host your own card images. Point this at a folder of <slug>.jpg/png/webp
# (e.g. your GitHub raw URL). Slugs look like "the-star", "six-of-wands", "ace-of-cups".
# If unset (or an image is missing), the app falls back to the public-domain
# Rider–Waite deck from Wikimedia Commons, so a card image ALWAYS loads.
# VITE_CARD_IMAGE_BASE=https://raw.githubusercontent.com/smayankthakur/Sitelytc-website/main/public/cards

# --- Razorpay (front end) ---
# Your PUBLIC Razorpay Key ID (safe to expose). Needed to open the checkout popup.
# If blank, the Subscribe button grants 30-day access directly (incubated mode).
VITE_RAZORPAY_KEY_ID=

# --- Edge function secrets (set with: supabase secrets set KEY=value) ---
# Preferred (matches the original Lovable stack):
# LOVABLE_API_KEY=...
# Fallback:
# OPENAI_API_KEY=...
# Optional model override:
# TAROT_MODEL=google/gemini-2.5-flash

# Razorpay server secrets (NEVER put the Key Secret in the front end):
# RAZORPAY_KEY_ID=rzp_live_xxx_or_rzp_test_xxx
# RAZORPAY_KEY_SECRET=your_key_secret      <-- keep private; set only as a server secret
# RAZORPAY_PLAN_ID=plan_xxxxxxxx
# RAZORPAY_TOTAL_COUNT=12

# Server-side enforcement (recommended for production):
# Run app/supabase/schema.sql first. SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are
# auto-provided to deployed edge functions — when present, the daily limit and the
# 30-day access are enforced server-side (not bypassable in the browser).
# DAILY_LIMIT=3
# ALLOWED_ORIGIN=https://your-app-domain.com   # restrict CORS in production
